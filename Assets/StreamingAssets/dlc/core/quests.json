        "id": "step_3",
        "name": "回禀长老",
        "description": "再次与张长老交谈，汇报修炼心得。",
        "objectives": [
          {
            "type": "talk_npc",
            "targetId": "core:elder_zhang",
            "description": "向张长老汇报"
          }
        ],
        "dialogueSnippet": "张长老欣慰一笑：「孺子可教也。这本《清心诀》便赠予你，望你日后勤加修行。」"
      }
